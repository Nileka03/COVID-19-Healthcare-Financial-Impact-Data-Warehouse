                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=17.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">SELECT 
    e.*,
    TRY_CAST(e.START AS DATETIME) AS Converted_Start,
    TRY_CAST(e.STOP  AS DATETIME) AS Converted_Stop,
    (SELECT TOP 1 CODE FROM dbo.Stage_Conditions  
     WHERE ENCOUNTER = e.Id) AS CONDITIONCODE,
    (SELECT TOP 1 CODE FROM dbo.Stage_Medications 
     WHERE ENCOUNTER = e.Id) AS MEDICATIONID,
    (SELECT TOP 1 CODE FROM dbo.Stage_Procedures  
     WHERE ENCOUNTER = e.Id) AS PROCEDURECODE
FROM dbo.Stage_Encounters e</property>

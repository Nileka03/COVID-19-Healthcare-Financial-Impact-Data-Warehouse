                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=17.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">DECLARE @CompleteTime DATETIME = ?;

UPDATE FactEncounter
SET 
    accm_txn_complete_time = @CompleteTime, 
    txn_process_time_hours = DATEDIFF(HOUR, accm_txn_create_time, @CompleteTime)
WHERE EncounterID = ?;</property>
